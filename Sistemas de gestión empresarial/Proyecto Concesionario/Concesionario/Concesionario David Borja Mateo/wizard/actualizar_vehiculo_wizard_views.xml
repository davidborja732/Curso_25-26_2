<odoo>
    <data>
        <record id="view_actualizar_vehiculo_wizard_form" model="ir.ui.view">
            <field name="name">concesionario.actualizar_vehiculo.wizard.form</field>
            <field name="model">concesionario.actualizar_vehiculo.wizard</field>
            <field name="arch" type="xml">
                <form string="Actualizar Vehículos">
                    <header>
                        <button name="action_previous" type="object" string="Anterior" states="paso2,paso3" class="btn-secondary"/>
                        <button name="action_next" type="object" string="Siguiente" states="paso1,paso2" class="oe_highlight"/>
                        <button name="action_apply" type="object" string="Aplicar" states="paso3" class="oe_highlight"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group states="paso1" string="1. Seleccionar Vehículos">
                            <field name="vehiculo_ids" widget="many2many_tags"/>
                        </group>
                        
                        <group states="paso2" string="2. Parámetros a Modificar">
                            <field name="nuevo_estado"/>
                            <field name="porcentaje_descuento"/>
                        </group>
                        
                        <group states="paso3" string="3. Confirmar Actualización">
                            <p>¿Estás seguro de que deseas aplicar estos cambios a los vehículos seleccionados?</p>
                        </group>
                    </sheet>
                    <footer>
                        <button special="cancel" string="Cancelar"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Acción para el wizard desde el menú Action de los vehículos -->
        <act_window id="action_actualizar_vehiculo_wizard"
            name="Actualizar Vehículos"
            res_model="concesionario.actualizar_vehiculo.wizard"
            binding_model="concesionario.vehiculo"
            view_mode="form"
            target="new"/>
    </data>
</odoo>
