<odoo>
    <data>
        <!-- HERENCIA DE VISTA DE RES.PARTNER PARA CLIENTE (Puntos 23, 24) -->
        <record id="view_concesionario_cliente_form_inherit" model="ir.ui.view">
            <field name="name">res.partner.concesionario.cliente.form.inherit</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <!-- Añadir campo personalizado después del campo VAT -->
                <xpath expr="//field[@name='vat']" position="after">
                    <field name="is_cliente_concesionario"/>
                </xpath>
                
                <!-- Ocultar campo website (Punto 24) -->
                <xpath expr="//field[@name='website']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
            </field>
        </record>

        <!-- ACTION CLIENTE -->
        <record id="action_concesionario_cliente" model="ir.actions.act_window">
            <field name="name">Clientes Concesionario</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="domain">[('is_cliente_concesionario', '=', True)]</field>
            <field name="context">{'default_is_cliente_concesionario': True}</field>
        </record>
    </data>
</odoo>
