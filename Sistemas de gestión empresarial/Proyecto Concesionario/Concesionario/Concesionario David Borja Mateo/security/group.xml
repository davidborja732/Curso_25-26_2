<odoo>
    <data>
        <record model="ir.module.category" id="module_category_concesionario">
            <field name="name">Concesionario</field>
            <field name="description">Niveles de acceso para Concesionario</field>
            <field name="sequence">10</field>
        </record>

        <!-- Rol: Mecánico -->
        <record id="group_concesionario_mecanico" model="res.groups">
            <field name="name">Mecánico</field>
            <field name="category_id" ref="module_category_concesionario"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Rol: Vendedor -->
        <record id="group_concesionario_vendedor" model="res.groups">
            <field name="name">Vendedor</field>
            <field name="category_id" ref="module_category_concesionario"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Rol: Director -->
        <record id="group_concesionario_director" model="res.groups">
            <field name="name">Director</field>
            <field name="category_id" ref="module_category_concesionario"/>
            <field name="implied_ids" eval="[(4, ref('group_concesionario_vendedor')), (4, ref('group_concesionario_mecanico'))]"/>
        </record>
    </data>
</odoo>
