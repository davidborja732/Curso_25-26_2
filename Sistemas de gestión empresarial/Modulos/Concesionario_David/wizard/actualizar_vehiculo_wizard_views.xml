<odoo>
    <data>
        <record id="view_actualizar_vehiculo_wizard_form" model="ir.ui.view">
            <field name="name">concesionario.actualizar_vehiculo.wizard.form</field>
            <field name="model">concesionario.actualizar_vehiculo.wizard</field>
            <field name="arch" type="xml">
                <form string="Actualizar Vehículos">
                    <header>
                        <button name="action_previous" type="object" string="Anterior" invisible="state not in ('paso2', 'paso3')" class="btn-secondary"/>
                        <button name="action_next" type="object" string="Siguiente" invisible="state not in ('paso1', 'paso2')" class="oe_highlight"/>
                        <button name="action_apply" type="object" string="Aplicar" invisible="state != 'paso3'" class="oe_highlight"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group invisible="state != 'paso1'" string="1. Seleccionar Vehículos">
                            <field name="vehiculo_ids" widget="many2many_tags"/>
                        </group>

                        <group invisible="state != 'paso2'" string="2. Parámetros a Modificar">
                            <field name="nuevo_estado"/>
                            <field name="porcentaje_descuento"/>
                        </group>

                        <group invisible="state != 'paso3'" string="3. Confirmar Actualización">
                            <p>¿Estás seguro de que deseas aplicar estos cambios a los vehículos seleccionados?</p>
                        </group>
                    </sheet>
                    <footer>
                        <button special="cancel" string="Cancelar"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_actualizar_vehiculo_wizard" model="ir.actions.act_window">
            <field name="name">Actualizar Vehículos</field>
            <field name="res_model">concesionario.actualizar_vehiculo.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="binding_model_id" ref="model_concesionario_vehiculo"/>
            <field name="binding_view_types">form,list</field>
        </record>
    </data>
</odoo>
