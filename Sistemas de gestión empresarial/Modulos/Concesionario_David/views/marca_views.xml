<odoo>
    <data>

        <record id="view_concesionario_marca_tree" model="ir.ui.view">
            <field name="name">concesionario.marca.tree</field>
        <field name="model">concesionario.marca</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="pais_origen"/>
            </list>
        </field>
        </record>

        <record id="view_concesionario_marca_form" model="ir.ui.view">
            <field name="name">concesionario.marca.form</field>
            <field name="model">concesionario.marca</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="pais_origen"/>
                        </group>
                        <notebook>
                            <page string="Vehículos de esta Marca">
                                <field name="vehiculos_ids"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_concesionario_marca" model="ir.actions.act_window">
            <field name="name">Marcas</field>
            <field name="res_model">concesionario.marca</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
